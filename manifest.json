{
  "manifest_version": 3,
  "name": "Canvas Notes & Dictation",
  "version": "1.0",
  "description": "A simple note-taking app with canvas and dictation.",
  "permissions": [
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}